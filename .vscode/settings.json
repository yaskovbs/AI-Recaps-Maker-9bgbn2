{
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#0b2a3222",
    "activityBar.activeBorder": "#4c9eb3",
    "activityBar.background": "#abbfc6",
    "activityBar.foreground": "#E6FAFF",
    "activityBar.inactiveForeground": "#1f292b",
    "activityBarBadge.background": "#020202",
    "activityBarBadge.foreground": "#030708",
    "statusBar.background": "#292f31",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.noFolderBackground": "#455458",
    "statusBar.debuggingBackground": "#0d0c0b",
    "statusBar.debuggingForeground": "#1c1515",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#32418c",
    "titleBar.inactiveBackground": "#071A21CC",
    "titleBar.inactiveForeground": "#6c8388",
    "sash.hoverBorder": "#262f31"
  },
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.defaultFormatter": "vscode.typescript-language-features",
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "files.exclude": {
    "**/.git": true,
    "**/dist": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/dist": true,
    "**/node_modules": true
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true
}
