SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Generate a random secret of at least 32 characters. Configure the identical
# value as PROCESSING_SECRET in Supabase Edge Function secrets.
PROCESSING_SECRET=replace-with-a-long-random-secret
# Optional but commonly required for YouTube from datacenter IPs. Export a
# fresh Netscape cookies.txt from a dedicated account, then base64-encode it.
YOUTUBE_COOKIES_B64=
WORKER_ID=recaps-worker-1
POLL_SECONDS=3
TASK_TIMEOUT_SECONDS=7200
MAX_VIDEO_DURATION_SECONDS=14400
MAX_SOURCE_BYTES=4294967296
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
