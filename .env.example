# OnSpace Cloud Backend Configuration
# Get these values from OnSpace Cloud Dashboard

# Backend URL - Example: https://xxx.backend.onspace.ai
VITE_SUPABASE_URL=your_onspace_cloud_backend_url_here

# Anonymous Key (Public) - Safe to expose in frontend
VITE_SUPABASE_ANON_KEY=your_onspace_cloud_anon_key_here

# ===================================
# HOW TO GET THESE VALUES:
# ===================================
# 1. Go to OnSpace Cloud Dashboard
# 2. Open your project
# 3. Click on "Cloud" tab (top right)
# 4. Go to "Settings" or "API Keys"
# 5. Copy VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
# 6. Paste them above (remove "your_..._here")
# 7. Save this file as ".env" (remove .example)
#
# Example:
# VITE_SUPABASE_URL=https://abc123xyz.backend.onspace.ai
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
