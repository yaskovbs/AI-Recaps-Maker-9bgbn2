# The URL of your Supabase/OnSpace project instance.
VITE_SUPABASE_URL=

# The public anonymous key for your Supabase project, safe for client-side use.
VITE_SUPABASE_ANON_KEY=

# Google OAuth credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Also configure these in OnSpace/Supabase dashboard under Auth > Providers > Google
# Callback URL for Google Cloud Console: https://<your-supabase-url>/auth/v1/callback
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=
